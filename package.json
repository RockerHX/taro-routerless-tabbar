{
  "name": "taro-routerless-tabbar",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm run build:types && pnpm run build:lib",
    "build:lib": "vite build -c vite.config.ts",
    "build:types": "vue-tsc -p tsconfig.build.json",
    "test:run": "vitest run -c vitest.config.ts",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "@tarojs/components": ">=4 <5",
    "@tarojs/taro": ">=4 <5",
    "vue": ">=3.3 <4"
  },
  "devDependencies": {
    "@tarojs/components": "4.2.0",
    "@tarojs/taro": "4.2.0",
    "@vitejs/plugin-vue": "^4.0.0",
    "@vue/compiler-sfc": "^3.3.0",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^15.11.7",
    "sass": "^1.60.0",
    "typescript": "^5.1.0",
    "vite": "^4.2.0",
    "vitest": "^0.34.6",
    "vue": "^3.3.0",
    "vue-tsc": "^2.1.10"
  }
}
