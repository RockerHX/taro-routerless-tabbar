{
  "name": "taro-routerless-tabbar",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm run build:clean && pnpm run build:types && pnpm run build:lib && pnpm run build:postprocess",
    "build:clean": "node ./scripts/clean-dist.mjs",
    "build:lib": "vite build -c vite.config.ts",
    "build:postprocess": "node ./scripts/postbuild.mjs",
    "build:types": "vue-tsc -p tsconfig.build.json",
    "format:check": "prettier . --check --ignore-unknown",
    "lint": "eslint src/**/*.ts src/**/*.vue *.ts",
    "pack:dry-run": "npm pack --dry-run",
    "prepublishOnly": "pnpm run lint && pnpm run format:check && pnpm run typecheck && pnpm run test:run && pnpm run build && pnpm run pack:dry-run",
    "test:run": "vitest run -c vitest.config.ts",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "@tarojs/components": ">=4 <5",
    "@tarojs/taro": ">=4 <5",
    "vue": ">=3.3 <4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^8.57.1",
    "@tarojs/cli": "4.2.0",
    "@tarojs/components": "4.2.0",
    "@tarojs/taro": "4.2.0",
    "@typescript-eslint/parser": "8.59.3",
    "@vitejs/plugin-vue": "^4.6.2",
    "@vue/compiler-sfc": "^3.5.38",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-taro": "4.2.0",
    "eslint-plugin-vue": "^8.7.1",
    "globals": "^17.6.0",
    "happy-dom": "^15.11.7",
    "prettier": "^3.8.4",
    "sass": "^1.101.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^4.5.14",
    "vitest": "^0.34.6",
    "vue": "^3.5.38",
    "vue-eslint-parser": "10.4.0",
    "vue-tsc": "^2.2.12"
  },
  "author": "rockerhx",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RockerHX/taro-routerless-tabbar.git"
  },
  "bugs": {
    "url": "https://github.com/RockerHX/taro-routerless-tabbar/issues"
  },
  "homepage": "https://github.com/RockerHX/taro-routerless-tabbar#readme",
  "keywords": [
    "taro",
    "tabbar",
    "vue3",
    "miniapp",
    "custom-tabbar",
    "routerless",
    "keep-alive"
  ]
}
