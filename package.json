{
  "name": "taro-routerless-tabbar",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm run build:clean && pnpm run build:types && pnpm run build:lib && pnpm run build:postprocess",
    "build:clean": "node ./scripts/clean-dist.mjs",
    "build:lib": "vite build -c vite.config.ts",
    "build:postprocess": "node ./scripts/postbuild.mjs",
    "build:types": "vue-tsc -p tsconfig.build.json",
    "format:check": "prettier . --check --ignore-unknown",
    "lint": "eslint src/**/*.ts src/**/*.vue *.ts",
    "pack:dry-run": "npm pack --dry-run",
    "prepublishOnly": "pnpm run lint && pnpm run format:check && pnpm run typecheck && pnpm run test:run && pnpm run build && pnpm run pack:dry-run",
    "test:run": "vitest run -c vitest.config.ts",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "prepare": "husky",
    "test:taro:h5": "pnpm run build && pnpm --dir examples/taro-vue3-basic install --frozen-lockfile && pnpm --dir examples/taro-vue3-basic run build:h5"
  },
  "peerDependencies": {
    "@tarojs/components": ">=4 <5",
    "@tarojs/taro": ">=4 <5",
    "vue": ">=3.3 <4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/parser": "8.61.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/compiler-sfc": "^3.5.38",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "sass": "^1.101.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "vue": "^3.5.38",
    "vue-eslint-parser": "10.4.1",
    "vue-tsc": "^3.3.5"
  },
  "author": "rockerhx",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RockerHX/taro-routerless-tabbar.git"
  },
  "bugs": {
    "url": "https://github.com/RockerHX/taro-routerless-tabbar/issues"
  },
  "homepage": "https://github.com/RockerHX/taro-routerless-tabbar#readme",
  "keywords": [
    "taro",
    "tabbar",
    "vue3",
    "miniapp",
    "custom-tabbar",
    "routerless",
    "keep-alive"
  ],
  "lint-staged": {
    "{eslint,vite,vitest}.config.{js,mjs,cjs,ts,mts,cts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "{src,scripts}/**/*.{js,mjs,cjs,ts,tsx,mts,cts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.vue": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{scss,css}": "prettier --write",
    "*.{json,html,md,yml,yaml}": "prettier --write",
    "{doc,scripts,src}/**/*.{json,html,md,yml,yaml}": "prettier --write"
  }
}
